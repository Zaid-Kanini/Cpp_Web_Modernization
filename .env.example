# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Use * for development only, never in production
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DATABASE_URL="postgresql://username:password@localhost:5432/tsm_dev?schema=public"

# Connection Pool Configuration
DATABASE_POOL_MIN=20
DATABASE_POOL_MAX=100
DATABASE_CONNECTION_TIMEOUT=10000
DATABASE_IDLE_TIMEOUT=30000

# ============================================
# JWT Authentication (OAuth 2.0)
# ============================================
# Generate secrets using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use different secrets for access and refresh tokens
# Minimum 256 bits (32 bytes) for production security
ACCESS_TOKEN_SECRET=your-access-token-secret-min-64-hex-chars-replace-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-64-hex-chars-replace-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# Security
# ============================================
# Will be configured in EP-AUTH epic
# BCRYPT_ROUNDS=10
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Email Service (SendGrid/AWS SES)
# ============================================
# Will be configured in EP-NOTIF epic
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=your-email-api-key
# EMAIL_FROM=noreply@example.com

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FILE_PATH=logs/

# ============================================
# External Services
# ============================================
# Add external service configurations here
