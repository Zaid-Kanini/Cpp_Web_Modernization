{
  "name": "@tsm/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Training Schedule Management - Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rimraf dist",
    "validate:openapi": "swagger-cli validate openapi.yaml",
    "bundle:openapi": "swagger-cli bundle openapi.yaml -o openapi.json -t json",
    "generate:types": "npx openapi-typescript openapi.yaml -o src/types/openapi.ts",
    "prebuild": "npm run generate:types",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "@types/nodemailer": "^7.0.11",
    "argon2": "^0.31.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "dependencies": {
  "@prisma/client": "^5.9.0",
  "@types/node": "^20.19.37",
  "@types/nodemailer": "^7.0.11",
  "argon2": "^0.31.0",
  "cookie-parser": "^1.4.7",
  "cors": "^2.8.5",
  "date-fns": "^3.0.0",
  "dotenv": "^16.4.0",
  "express": "^4.19.0",
  "helmet": "^7.1.0",
  "js-yaml": "^4.1.0",
  "jsonwebtoken": "^9.0.2",
  "nodemailer": "^8.0.2",
  "passport": "^0.7.0",
  "passport-jwt": "^4.0.1",
  "swagger-ui-express": "^5.0.0",
  "uuid": "^13.0.0",
  "winston": "^3.19.0",
  "zod": "^3.22.4"
}
}
